generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Room {
  id            Int       @id @default(autoincrement()) @db.UnsignedInt
  name          String    @unique @db.VarChar(32)
  token         String    @unique @db.VarChar(64)
  allowApiQuery Boolean   @default(true) @map("allow_api_query")
  createdAt     BigInt    @default(0) @map("created_at") @db.UnsignedBigInt
  messages      Message[]

  @@index([token], map: "idx_rooms_token")
  @@map("rooms")
}

model Message {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  roomId    Int    @map("room_id") @db.UnsignedInt
  room      String @db.VarChar(32)
  key       String @db.VarChar(64)
  valueJson Json   @map("value_json")
  createdAt BigInt @default(0) @map("created_at") @db.UnsignedBigInt
  roomRef   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, id], map: "idx_messages_room_id")
  @@index([room, createdAt, id], map: "idx_messages_room_created")
  @@index([createdAt, id], map: "idx_messages_created")
  @@map("messages")
}
